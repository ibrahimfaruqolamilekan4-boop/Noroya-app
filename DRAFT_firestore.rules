rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isCleric() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "cleric";
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // VALIDATION HELPERS
    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ["user", "cleric", "admin"] &&
             data.createdAt == request.time;
    }

    function isValidVideo(data) {
      return data.clericId is string && isValidId(data.clericId) &&
             data.videoUrl is string && data.videoUrl.size() <= 1000 &&
             data.title is string && data.title.size() <= 200 &&
             data.likes is number && data.views is number &&
             data.createdAt == request.time;
    }

    function isValidQuestion(data) {
      return data.userId is string && isValidId(data.userId) &&
             data.clericId is string && isValidId(data.clericId) &&
             data.content is string && data.content.size() <= 2000 &&
             data.status in ["pending", "answered", "rejected"] &&
             data.createdAt == request.time;
    }

    // RULES
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.role == 'cleric' || isOwner(userId) || isAdmin());
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role != 'admin';
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Prevent role change unless admin
        (incoming().role == existing().role && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'bio', 'photoURL', 'specialty'])) ||
        isAdmin()
      );
    }

    match /videos/{videoId} {
      allow read: if true; // Public feed
      allow create: if isCleric() && isValidVideo(incoming()) && incoming().clericId == request.auth.uid;
      allow update: if (isCleric() && incoming().clericId == request.auth.uid && isValidVideo(incoming()) && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'thumbnailUrl'])) ||
                       (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'views', 'shares'])) || // Meta updates
                       isAdmin();
      allow delete: if (isCleric() && existing().clericId == request.auth.uid) || isAdmin();
    }

    match /questions/{questionId} {
      allow read: if isSignedIn() && (isOwner(existing().userId) || isOwner(existing().clericId) || isAdmin());
      allow create: if isSignedIn() && isValidQuestion(incoming()) && incoming().userId == request.auth.uid &&
                       exists(/databases/$(database)/documents/users/$(incoming().clericId)); // Ensure cleric exists
      allow update: if isSignedIn() && (
        // User cancelling their own question
        (isOwner(existing().userId) && incoming().status == 'rejected' && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        // Cleric answering
        (isOwner(existing().clericId) && isValidQuestion(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['answer', 'answerType', 'status', 'answeredAt']) &&
         incoming().status in ['answered', 'rejected'] &&
         incoming().answeredAt == request.time) ||
        isAdmin()
      );
    }

    match /users/{userId}/follows/{clericId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidId(clericId) && exists(/databases/$(database)/documents/users/$(clericId));
      allow delete: if isOwner(userId);
    }

    match /videos/{videoId}/likes/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidId(videoId);
      allow delete: if isOwner(userId);
    }

    match /admins/{userId} {
      allow read: if isOwner(userId);
    }
  }
}
